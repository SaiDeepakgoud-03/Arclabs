{
  "buildCommand": "CI=false DISABLE_ESLINT_PLUGIN=true npm run build",
  "outputDirectory": "build",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/:path(.*)",
      "destination": "https://api.example.com/:path"
    },
    {
      "source": "/:path(.*)",
      "destination": "/index.html"
    }
  ]
}