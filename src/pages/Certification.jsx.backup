/* ═══════════════════════════════════════ HELPERS ═══════════════════════════════════════ */
function genCertId() {
  const chars = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
  return (
    "ARC" +
    Array.from(
      { length: 4 },
      () => chars[Math.floor(Math.random() * chars.length)],
    ).join("")
  );
}

function lookupPin(pin) {
  if (pin.length < 3) return null;
  return PIN_MAP[pin.slice(0, 3)] || null;
}

function fmtDate(d) {
  if (!d) return "—";
  return new Date(d).toLocaleDateString("en-IN", {
    day: "2-digit",
    month: "long",
    year: "numeric",
  });
}

function getSkills(tech, days) {
  const all = SKILLS_MAP[tech] || [
    "IoT Fundamentals",
    "Sensor Programming",
    "Cloud Integration",
  ];
  if (days >= 5) return all;
  if (days === 3) return all.slice(0, 4);
  return all.slice(0, 3);
}

function getTechObj(id) {
  return TECHNOLOGIES.find((t) => t.id === id) || { id, label: id, icon: "🔧" };
}

function getDurLabel(days) {
  if (days == 2) return "2-Day Workshop";
  if (days == 3) return "3-Day Intensive";
  return "5-Day Bootcamp";
}

function getHours(days) {
  const h = { 2: 14, 3: 21, 5: 35 };
  return (h[days] || days * 7) + " Hours";
}

/* ═══════════════════════════════════════ CERT CARD ═══════════════════════════════════════ */
function CertCard({ cert }) {
  const tech = getTechObj(cert.technology);
  return (
    <div className="dcert">
      <div className="dc-wm">ARC LABS</div>
      <div className="dcert-topbar" />
      <div className="dcert-inner">
        {/* Header */}
        <div className="dc-hd">
          <div className="dc-brand">
            <div className="dc-brand-dot" />
            <div>
              <div className="dc-brand-name">ARC LABS</div>
              <div className="dc-brand-tag">
                MSME REGISTERED · HYDERABAD, INDIA
              </div>
            </div>
          </div>
          <div className="dc-id-chip">
            <span style={{ opacity: 0.55, marginRight: 3 }}>#</span>
            {cert.certId}
          </div>
        </div>

        {/* Name */}
        <div className="dc-center">
          <div className="dc-certifies">This is to certify that</div>
          <div className="dc-name">{cert.fullName}</div>
          <div className="dc-completed">
            has successfully completed the{" "}
            <strong>
              {getDurLabel(cert.durationDays)} in {tech.label}
            </strong>{" "}
            {/* with Grade{" "}
            <strong
              style={{
                color:
                  cert.grade === "A+"
                    ? "var(--lime)"
                    : cert.grade === "A"
                      ? "var(--teal)"
                      : "var(--gold)",
              }}
            >
              {cert.grade}
            </strong>{" "}
            — {cert.performance} Performance */}
          </div>
        </div>

        {/* Program */}
        <div className="dc-prog">
          <div className="dc-prog-lbl">Program Completed</div>
          <div className="dc-prog-name">
            {tech.icon} {tech.label}
          </div>
          <div className="dc-prog-sub">
            {getDurLabel(cert.durationDays)}
            {/* · {getHours(cert.durationDays)} of
            Practical Training */}
          </div>
        </div>

        {/* Details grid */}
        <div className="dc-grid">
          {[
            { k: "Student Name", v: cert.fullName },
            { k: "Phone Number", v: cert.phone },
            { k: "Institution", v: cert.institution },
            {
              k: "Institution Type",
              v:
                cert.institutionType?.charAt(0).toUpperCase() +
                cert.institutionType?.slice(1),
            },
            { k: "Training Date", v: fmtDate(cert.trainingDate) },
            { k: "Certificate Issued", v: fmtDate(cert.issueDate) },
            { k: "City / State", v: `${cert.city}, ${cert.state}` },
            { k: "PIN Code", v: cert.pincode },
            { k: "Technology", v: cert.technology },
            {
              k: "Duration",
              v: `${cert.durationDays} Days (${getHours(cert.durationDays)})`,
            },
            {
              k: "Certificate Type",
              v: `${cert.performance}`,
            },

            { k: "Trainer", v: cert.trainer || "ARC LABS Certified Trainer" },
            { k: "Certificate Status", v: "✓ ACTIVE & VERIFIED" },
          ].map((d) => (
            <div className="dc-cell" key={d.k}>
              <div className="dc-cell-k">{d.k}</div>
              <div
                className="dc-cell-v"
                style={
                  d.k === "Certificate Status" ? { color: "var(--lime)" } : {}
                }
              >
                {d.v}
              </div>
            </div>
          ))}
        </div>

        {/* Skills */}
        <div className="dc-skills">
          <div className="dc-skills-lbl">
            Skills & Competencies Demonstrated
          </div>
          <div className="dc-chips">
            {cert.skills.map((s, i) => (
              <span key={s} className={`dc-chip${i < 2 ? " hi" : ""}`}>
                {s}
              </span>
            ))}
          </div>
        </div>

        {/* Footer */}
        <div className="dc-ft">
          <div className="dc-sig">
            <div className="dc-sig-line" />
            <div className="dc-sig-name">
              {cert.trainer || "ARC LABS Trainer"}
            </div>
            <div className="dc-sig-role">CERTIFIED TRAINER · ARC LABS</div>
          </div>
          <div className="dc-seal">🏛️</div>
          <div className="dc-sig">
            <div className="dc-sig-line" />
            <div className="dc-sig-name">ARC LABS Academy</div>
            <div className="dc-sig-role">DIRECTOR · CERTIFICATION PROGRAM</div>
          </div>
        </div>
      </div>
    </div>
  );
}

/* ═══════════════════════════════════════ VERIFY TAB ═══════════════════════════════════════ */
function VerifyTab({ allCerts, onSuccess }) {
  const [q, setQ] = useState("");
  const [loading, setLoading] = useState(false);
  const [result, setResult] = useState(null);
  const [error, setError] = useState("");
  const [toast, setToast] = useState("");

  const doVerify = (id) => {
    const sid = (id || q).trim().toUpperCase();
    if (!sid) return;
    setLoading(true);
    setError("");
    setResult(null);
    setTimeout(() => {
      const cert = allCerts[sid];
      if (cert) {
        setResult(cert);
        onSuccess && onSuccess(cert);
      } else
        setError(
          `No certificate found with ID "${sid}". Check the ID and try again.`,
        );
      setLoading(false);
    }, 850);
  };

  const copy = () => {
    navigator.clipboard.writeText(result?.certId || "").catch(() => {});
    setToast("Certificate ID copied!");
    setTimeout(() => setToast(""), 2000);
  };

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: "1.3rem" }}>
      <div className="vcard">
        <div className="vcard-eye">Certificate Verification</div>
        <div className="vcard-title">Verify Authenticity</div>
        <div className="vcard-sub">
          Enter the ARC LABS Certificate ID (7 characters, e.g. ARC4F2K) to
          instantly verify and view the complete certificate record.
        </div>
        <div className="srow">
          <input
            className="cert-inp"
            placeholder="Enter Certificate ID — e.g. ARC4F2K"
            value={q}
            maxLength={9}
            onChange={(e) => setQ(e.target.value.toUpperCase())}
            onKeyDown={(e) => e.key === "Enter" && doVerify()}
          />
          <button
            className="btn-v"
            onClick={() => doVerify()}
            disabled={loading || !q.trim()}
          >
            {loading ? "⏳ Verifying..." : "🔍 Verify"}
          </button>
        </div>
        {/* <div className="demo-hint">
          <strong style={{ color: "var(--gold)" }}>Demo IDs to try:</strong>{" "}
          {Object.keys(allCerts).map((id, i) => (
            <span key={id}>
              <button
                className="demo-id"
                onClick={() => {
                  setQ(id);
                  doVerify(id);
                }}
              >
                {id}
              </button>
              {i < Object.keys(allCerts).length - 1 ? " · " : ""}
            </span>
          ))}
        </div> */}
      </div>

      {error && <div className="verr">❌ {error}</div>}

      {result && (
        <div style={{ animation: "fadein .4s ease" }}>
          <div className="vsuccess-badge">
            <span className="vsb-icon">✅</span>
            <div className="vsb-text">
              <strong>Certificate Verified — Authentic & Active</strong>
              <span>
                Issued by ARC LABS · Certificate ID:{" "}
                <span
                  style={{
                    fontFamily: "monospace",
                    letterSpacing: ".05em",
                    color: "var(--teal)",
                  }}
                >
                  {result.certId}
                </span>
              </span>
            </div>
          </div>
          <CertCard cert={result} />
          <div className="cert-acts" style={{ marginTop: "1rem" }}>
            <button className="btn-act primary" onClick={copy}>
              📋 Copy Certificate ID
            </button>
            <button className="btn-act ghost" onClick={() => window.print()}>
              🖨️ Print
            </button>
            <a
              className="btn-act ghost"
              href={`https://wa.me/?text=My ARC LABS Certificate: ${result.certId} — Verify at arclabs.in/verify`}
              target="_blank"
              rel="noreferrer"
            >
              💬 Share
            </a>
          </div>
        </div>
      )}

      {toast && <div className="toast">✓ {toast}</div>}
    </div>
  );
}

/* ═══════════════════════════════════════ REGISTER TAB ═══════════════════════════════════════ */
function RegisterTab({ onRegistered }) {
  const STEPS = 3;
  const [step, setStep] = useState(1);
  const [pinStatus, setPinStatus] = useState("idle");
  const [submitting, setSubmitting] = useState(false);
  const [issued, setIssued] = useState(null);
  const [toast, setToast] = useState("");
  const [form, setForm] = useState({
    fullName: "",
    phone: "",
    email: "",
    institutionType: "college",
    institution: "",
    trainingDate: "",
    pincode: "",
    city: "",
    state: "",
    technology: "",
    durationDays: "",
    performance: "",
    projectTitle: "",
    trainer: "",
    achievement: "",
    notes: "",
  });

  const set = (k, v) => setForm((p) => ({ ...p, [k]: v }));

  /* Pincode auto-fetch using India Post API + fallback to local map */
  const handlePin = async (pin) => {
    set("pincode", pin);
    if (pin.length === 6) {
      setPinStatus("loading");
      set("city", "");
      set("state", "");
      try {
        // Try India Post API
        const res = await fetch(`https://api.postalpincode.in/pincode/${pin}`);
        const data = await res.json();
        if (data[0]?.Status === "Success" && data[0]?.PostOffice?.length > 0) {
          const po = data[0].PostOffice[0];
          set("city", po.District || po.Block || po.Name);
          set("state", po.State);
          setPinStatus("found");
          return;
        }
      } catch (e) {
        /* fallback */
      }
      // Local map fallback
      const found = lookupPin(pin);
      if (found) {
        set("city", found.c);
        set("state", found.s);
        setPinStatus("found");
      } else {
        setPinStatus("notfound");
      }
    } else {
      setPinStatus("idle");
      if (pin.length < 6) {
        set("city", "");
        set("state", "");
      }
    }
  };

  const step1ok =
    form.fullName.trim() &&
    form.phone.trim().length >= 10 &&
    form.institution.trim() &&
    form.trainingDate &&
    form.pincode.length === 6 &&
    form.city &&
    form.state;
  const step2ok = form.technology && form.durationDays;
  const step3ok = form.performance;

  const submit = () => {
    if (!step3ok) return;
    setSubmitting(true);
    setTimeout(() => {
      const certId = genCertId();
      const days = parseInt(form.durationDays);
      const skills = getSkills(form.technology, days);
      const grade = GRADE[form.performance] || "B";
      const issueDate = new Date().toISOString().split("T")[0];
      const cert = {
        ...form,
        certId,
        durationDays: days,
        skills,
        grade,
        issueDate,
        status: "ACTIVE",
      };
      onRegistered(cert);
      setIssued(cert);
      setSubmitting(false);
    }, 1800);
  };

  const copyId = () => {
    navigator.clipboard.writeText(issued?.certId || "").catch(() => {});
    setToast("Copied!");
    setTimeout(() => setToast(""), 2000);
  };

  const reset = () => {
    setIssued(null);
    setStep(1);
    setPinStatus("idle");
    setForm({
      fullName: "",
      phone: "",
      email: "",
      institutionType: "college",
      institution: "",
      trainingDate: "",
      pincode: "",
      city: "",
      state: "",
      technology: "",
      durationDays: "",
      performance: "",
      projectTitle: "",
      trainer: "",
      achievement: "",
      notes: "",
    });
  };

  /* ─── SUCCESS ─── */
  if (issued) {
    const tech = getTechObj(issued.technology);
    return (
      <div className="rcard">
        <div className="rcard-body">
          <div className="succ-wrap">
            <span className="succ-icon">🎓</span>
            <div className="succ-title">Certificate Registered!</div>
            <p className="succ-sub">
              Your ARC LABS certificate has been officially registered. Save
              your Certificate ID — share it with employers, institutions, or
              anywhere credentials matter.
            </p>

            <div className="cid-box">
              <div className="cid-lbl">Your Certificate ID</div>
              <div className="cid-val">{issued.certId}</div>
              <button
                className={`cid-copy${toast ? " cp" : ""}`}
                onClick={copyId}
              >
                {toast ? "✓ Copied!" : "📋 Copy ID"}
              </button>
            </div>

            <div className="mini-cert">
              {[
                ["Full Name", issued.fullName],
                ["Technology", `${tech.icon} ${issued.technology}`],
                ["Program", getDurLabel(issued.durationDays)],
                ["Training Date", fmtDate(issued.trainingDate)],
                ["Institution", issued.institution],
                ["City / State", `${issued.city}, ${issued.state}`],
                ["Grade", `${issued.grade} — ${issued.performance}`],
                ["Issue Date", fmtDate(issued.issueDate)],
              ].map(([k, v]) => (
                <div className="mc-row" key={k}>
                  <span className="mc-k">{k}</span>
                  <span className="mc-v">{v}</span>
                </div>
              ))}
            </div>

            <div className="succ-acts">
              <button
                className="btn-act primary"
                onClick={() => window.location.reload()}
              >
                🔍 Verify My Certificate
              </button>
              <button className="btn-act ghost" onClick={reset}>
                + Register Another
              </button>
            </div>
          </div>
        </div>
        {toast && <div className="toast">✓ {toast}</div>}
      </div>
    );
  }

  /* ─── FORM ─── */
  return (
    <div className="rcard">
      <div className="rcard-hd">
        <div className="rcard-top">
          <div className="rcard-title">Register Your Certificate</div>
          <div className="live-pill">
            <span className="live-dot" />
            LIVE SYSTEM
          </div>
        </div>
        <div className="rcard-sub">
          Fill in your training details to receive a unique 7-character
          Certificate ID. This ID verifies your credential across institutions
          and employers.
        </div>
      </div>
      <div className="rcard-body">
        {/* Progress */}
        <div className="pbar">
          {[1, 2, 3].map((n, i) => (
            <>
              <div
                key={`d${n}`}
                className={`pbar-dot${step > n ? "done" : step === n ? " active" : ""}`}
              >
                {step > n ? "✓" : n}
              </div>
              {i < 2 && (
                <div
                  key={`s${n}`}
                  className={`pbar-seg${step > n + 1 ? " done" : step === n + 1 ? " active" : ""}`}
                />
              )}
            </>
          ))}
        </div>
        <div className="slbl">
          Step <strong>{step}</strong> of {STEPS} —{" "}
          {step === 1
            ? "Personal & Institution Details"
            : step === 2
              ? "Training Information"
              : "Performance & Extras"}
        </div>

        {/* ─── STEP 1 ─── */}
        {step === 1 && (
          <>
            <div className="fg">
              <div className="fr">
                <div className="fl">
                  Full Name<span style={{ color: "var(--rose)" }}>*</span>
                </div>
                <input
                  className="fi"
                  placeholder="As it should appear on certificate"
                  value={form.fullName}
                  onChange={(e) => set("fullName", e.target.value)}
                />
              </div>
              <div className="fr">
                <div className="fl">
                  Phone Number<span style={{ color: "var(--rose)" }}>*</span>
                </div>
                <input
                  className="fi"
                  type="tel"
                  placeholder="10-digit mobile number"
                  value={form.phone}
                  onChange={(e) =>
                    set("phone", e.target.value.replace(/\D/g, "").slice(0, 10))
                  }
                  maxLength={10}
                />
              </div>
              <div className="fr">
                <div className="fl">Email Address</div>
                <input
                  className="fi"
                  type="email"
                  placeholder="Optional — for soft copy"
                  value={form.email}
                  onChange={(e) => set("email", e.target.value)}
                />
              </div>
              <div className="fr">
                <div className="fl">
                  Training / Completion Date{" "}
                  <span style={{ color: "var(--rose)" }}>*</span>
                </div>
                <input
                  className="fi"
                  type="date"
                  value={form.trainingDate}
                  onChange={(e) => set("trainingDate", e.target.value)}
                  max={new Date().toISOString().split("T")[0]}
                />
              </div>
            </div>

            <div className="fr">
              <div className="fl">Institution Type</div>
              <div style={{ display: "flex", gap: ".45rem", flexWrap: "wrap" }}>
                {[
                  "school",
                  "college",
                  "university",
                  "corporate",
                  "individual",
                ].map((t) => (
                  <button
                    key={t}
                    className={`itypebtn${form.institutionType === t ? " sel" : ""}`}
                    onClick={() => set("institutionType", t)}
                  >
                    {t === "school"
                      ? "🏫"
                      : t === "college"
                        ? "🏛️"
                        : t === "university"
                          ? "🎓"
                          : t === "corporate"
                            ? "🏢"
                            : "👤"}{" "}
                    {t.charAt(0).toUpperCase() + t.slice(1)}
                  </button>
                ))}
              </div>
            </div>

            <div className="fr">
              <div className="fl">
                School / College / Institution Name{" "}
                <span style={{ color: "var(--rose)" }}>*</span>
              </div>
              <input
                className="fi"
                placeholder="Full official name of your institution"
                value={form.institution}
                onChange={(e) => set("institution", e.target.value)}
              />
            </div>

            {/* Pincode */}
            <div className="fg">
              <div className="fr">
                <div className="fl">
                  PIN Code <span style={{ color: "var(--rose)" }}>*</span>
                  <span className="fl-hint">Auto-fills city & state</span>
                </div>
                <div className="pin-wrap">
                  <input
                    className={`fi${pinStatus === "loading" ? " loading" : pinStatus === "found" ? " ok" : pinStatus === "notfound" ? " err" : ""}`}
                    placeholder="6-digit PIN code"
                    value={form.pincode}
                    maxLength={6}
                    onChange={(e) =>
                      handlePin(e.target.value.replace(/\D/g, ""))
                    }
                  />
                  {pinStatus === "loading" && <div className="pin-spin" />}
                  {pinStatus === "found" && <div className="pin-ok">✓</div>}
                </div>
                {pinStatus === "found" && (
                  <div className="fhint ok">
                    ✓ Location auto-filled from PIN code
                  </div>
                )}
                {pinStatus === "notfound" && (
                  <div className="fhint err">
                    PIN not found — please fill city & state manually
                  </div>
                )}
              </div>
              <div className="fr">
                <div className="fl">
                  City <span style={{ color: "var(--rose)" }}>*</span>
                </div>
                <input
                  className="fi"
                  placeholder="Your city"
                  value={form.city}
                  onChange={(e) => set("city", e.target.value)}
                />
              </div>
            </div>
            <div className="fr">
              <div className="fl">
                State <span style={{ color: "var(--rose)" }}>*</span>
              </div>
              <select
                className="fs"
                value={form.state}
                onChange={(e) => set("state", e.target.value)}
              >
                <option value="">Select your state</option>
                {STATES.map((s) => (
                  <option key={s}>{s}</option>
                ))}
              </select>
            </div>

            <div className="rnav">
              <span />
              <button
                className="btn-next"
                onClick={() => setStep(2)}
                disabled={!step1ok}
              >
                Next → Training Info
              </button>
            </div>
          </>
        )}

        {/* ─── STEP 2 ─── */}
        {step === 2 && (
          <>
            <div className="fr">
              <div className="fl">
                Technology Enrolled In{" "}
                <span style={{ color: "var(--rose)" }}>*</span>
              </div>
              <div className="tech-grid">
                {TECHNOLOGIES.map((t) => (
                  <div
                    key={t.id}
                    className={`tech-opt${form.technology === t.id ? " sel" : ""}`}
                    onClick={() => set("technology", t.id)}
                  >
                    <span className="tech-opt-icon">{t.icon}</span>
                    <span>{t.id}</span>
                  </div>
                ))}
              </div>
              {form.technology && (
                <div className="fhint ok">
                  ✓ {getTechObj(form.technology).label}
                </div>
              )}
            </div>

            <div className="fr">
              <div className="fl">
                Training Duration{" "}
                <span style={{ color: "var(--rose)" }}>*</span>
              </div>
              <div className="dpills">
                {DURATIONS.map((d) => (
                  <button
                    key={d.val}
                    className={`dpill${form.durationDays === d.val ? " sel" : ""}`}
                    onClick={() => set("durationDays", d.val)}
                  >
                    {d.label}{" "}
                    <span style={{ fontSize: ".72rem", opacity: 0.65 }}>
                      · {d.sub.split("·")[1]?.trim()}
                    </span>
                  </button>
                ))}
              </div>
              {form.durationDays && (
                <div className="fhint ok">
                  ✓ {getDurLabel(form.durationDays)} ·{" "}
                  {getHours(parseInt(form.durationDays))}
                </div>
              )}
            </div>

            <div className="fg">
              <div className="fr">
                <div className="fl">Trainer / Faculty Name</div>
                <input
                  className="fi"
                  placeholder="ARC LABS certified trainer name"
                  value={form.trainer}
                  onChange={(e) => set("trainer", e.target.value)}
                />
              </div>
            </div>

            {/* <div className="fr">
              <div className="fl">Special Achievement / Award</div>
              <input
                className="fi"
                placeholder="e.g. Best Project Award, First Place Hackathon"
                value={form.achievement}
                onChange={(e) => set("achievement", e.target.value)}
              />
            </div> */}

            <div className="rnav">
              <button className="btn-bk" onClick={() => setStep(1)}>
                ← Back
              </button>
              <button
                className="btn-next"
                onClick={() => setStep(3)}
                disabled={!step2ok}
              >
                Next → Performance
              </button>
            </div>
          </>
        )}

        {/* ─── STEP 3 ─── */}
        {step === 3 && (
          <>
            <div className="fr">
              <div className="fl">
                Type Of Certificate
                <span style={{ color: "var(--rose)" }}>*</span>
                {/* <span className="fl-hint">As assessed by trainer</span> */}
              </div>
              <div className="pfbtns">
                {CERTIFICATE.map((p) => (
                  <button
                    key={p}
                    className={`pfbtn${form.performance === p ? ` s-${p.toLowerCase()}` : ""}`}
                    onClick={() => set("performance", p)}
                  >
                    {p === "Excellence"
                      ? "🏆"
                      : p === "Participation"
                        ? "⭐"
                        : p === "Coordination"
                          ? "👍"
                          : "📘"}{" "}
                    {p}
                  </button>
                ))}
              </div>
              {form.performance && (
                <div className="fhint ok">
                  <strong>{GRADE[form.performance]}</strong>
                  {form.performance}
                </div>
              )}
            </div>

            <div className="fr">
              <div className="fl">Trainer Feedback</div>
              <textarea
                className="fta"
                placeholder="Any extra achievements, special mentions, topics covered, or notes about the training..."
                value={form.notes}
                onChange={(e) => set("notes", e.target.value)}
                rows={3}
              />
            </div>

            {/* Summary preview */}
            {form.performance && (
              <div className="preview-box">
                <div className="pb-lbl">Certificate Preview</div>
                {[
                  ["Name", form.fullName],
                  ["Institution", form.institution],
                  [
                    "Technology",
                    `${getTechObj(form.technology).icon} ${form.technology} — ${getDurLabel(form.durationDays)}`,
                  ],
                  ["Location", `${form.city}, ${form.state} – ${form.pincode}`],
                  ["Grade", `${GRADE[form.performance]} (${form.performance})`],
                ].map(([k, v]) => (
                  <div className="pb-row" key={k}>
                    <span className="pb-k">{k}</span>
                    <span className="pb-v">{v}</span>
                  </div>
                ))}
              </div>
            )}

            <div className="rnav">
              <button className="btn-bk" onClick={() => setStep(2)}>
                ← Back
              </button>
              <button
                className="btn-next"
                onClick={submit}
                disabled={!step3ok || submitting}
              >
                {submitting
                  ? "⏳ Registering..."
                  : "🎓 Register & Get Certificate ID"}
              </button>
            </div>
          </>
        )}
      </div>
    </div>
  );
}

/* ═══════════════════════════════════════ MAIN ═══════════════════════════════════════ */
export default function CertificationPage() {
  const [tab, setTab] = useState("verify");
  const [allCerts, setAllCerts] = useState(() => {
    try {
      const saved = localStorage.getItem("arclabs_certs");
      return saved
        ? { ...SAMPLE_CERTS, ...JSON.parse(saved) }
        : { ...SAMPLE_CERTS };
    } catch {
      return { ...SAMPLE_CERTS };
    }
  });
  const [recentlyVerified, setRecentlyVerified] = useState([]);

  const handleRegister = (cert) => {
    setAllCerts((prev) => {
      const next = { ...prev, [cert.certId]: cert };
      try {
        localStorage.setItem("arclabs_certs", JSON.stringify(next));
      } catch {}
      return next;
    });
  };

  const handleVerified = (cert) => {
    setRecentlyVerified((prev) =>
      [cert, ...prev.filter((c) => c.certId !== cert.certId)].slice(0, 5),
    );
  };

  return (
    <>
      <style>{css}</style>

      {/* NAV */}
      <nav className="vnav">
        <a href="/" className="vnav-logo">
          <span className="vdot" />
          ARC LABS
        </a>
        <div className="vnav-links">
          <a href="/" className="vnav-link">
            ← Home
          </a>
          <a href="/programs" className="vnav-link">
            Programs
          </a>
          <a href="/products" className="vnav-link">
            Products
          </a>
        </div>
      </nav>

      {/* HERO */}
      <div className="vhero">
        <div className="vtag">
          <span className="vtdot" />
          Official Certification Registry · ARC LABS
        </div>
        <h1>
          Verify or Register
          <br />
          your <em>ARC LABS Certificate.</em>
        </h1>
        <p>
          Every ARC LABS training certificate is registered in our system.
          Verify any certificate instantly, or register your training to receive
          a unique Certificate ID.
        </p>
      </div>

      {/* TABS */}
      <div className="mtabs">
        <button
          className={`mtab${tab === "verify" ? " active" : ""}`}
          onClick={() => setTab("verify")}
        >
          🔍 Verify Certificate
        </button>
        <button
          className={`mtab${tab === "register" ? " active" : ""}`}
          onClick={() => setTab("register")}
        >
          📝 Register Certificate
        </button>
      </div>

      {/* CONTENT */}
      <div className="vcontent">
        {tab === "verify" && (
          <>
            <VerifyTab allCerts={allCerts} onSuccess={handleVerified} />
            {/* {recentlyVerified.length > 0 && (
              <div className="recent-sec">
                <div className="recent-lbl">Recently Verified</div>
                <div className="recent-list">
                  {recentlyVerified.map((c) => (
                    <div className="ri" key={c.certId}>
                      <div className="ri-l">
                        <span className="ri-ico">
                          {getTechObj(c.technology).icon}
                        </span>
                        <div>
                          <div className="ri-cid">{c.certId}</div>
                          <div className="ri-name">
                            {c.fullName} · {c.technology}
                          </div>
                        </div>
                      </div>
                      <span className="ri-r">
                        {c.city}, {c.state}
                      </span>
                    </div>
                  ))}
                </div>
              </div>
            )} */}
          </>
        )}
        {tab === "register" && <RegisterTab onRegistered={handleRegister} />}
      </div>

      {/* FOOTER */}
      {/* <div className="vfoot">
        <span>
          © 2025 ARC LABS · MSME Registered · Hyderabad · Official Certification
          Registry
        </span>
        <span>hello@arclabs.in · +91 8699929532</span>
      </div>

      <a
        href="https://wa.me/918699929532"
        className="wa-f"
        target="_blank"
        rel="noreferrer"
      >
        💬
      </a> */}
    </>
  );
}
