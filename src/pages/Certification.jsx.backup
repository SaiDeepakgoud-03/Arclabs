import { useState, useEffect, useRef } from "react";

/* ═══════════════════════════════════════ STYLES ═══════════════════════════════════════ */
const css = `
@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,700;0,900;1,700;1,900&display=swap');

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#060612;--deep:#0A0A1A;--panel:#0F0F22;--card:#13132A;--card2:#181832;--raised:#1D1D3A;
  --line:rgba(255,255,255,0.06);--line2:rgba(255,255,255,0.11);--line3:rgba(255,255,255,0.18);
  --snow:#EEEEFF;--fog:#7878A0;--mist:#AAABCC;
  --teal:#00E8D4;--lime:#7DFF6B;--gold:#FFD166;--violet:#A855F7;--rose:#FF5C87;--amber:#FFA843;
  --teal-g:rgba(0,232,212,0.12);--lime-g:rgba(125,255,107,0.10);--gold-g:rgba(255,209,102,0.12);
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--snow);font-family:'DM Sans',sans-serif;line-height:1.65;overflow-x:hidden;min-height:100vh}
::selection{background:var(--teal);color:var(--bg)}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-track{background:var(--bg)}::-webkit-scrollbar-thumb{background:var(--teal);border-radius:2px}

body::before{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background:
    radial-gradient(ellipse 55% 45% at 15% 15%,rgba(0,232,212,0.05) 0%,transparent 65%),
    radial-gradient(ellipse 45% 55% at 85% 85%,rgba(125,255,107,0.04) 0%,transparent 65%),
    linear-gradient(rgba(255,255,255,0.013) 1px,transparent 1px),
    linear-gradient(90deg,rgba(255,255,255,0.013) 1px,transparent 1px);
  background-size:100% 100%,100% 100%,50px 50px,50px 50px;
}

/* NAV */
.vnav{position:sticky;top:0;z-index:300;height:64px;padding:0 5vw;display:flex;align-items:center;justify-content:space-between;background:rgba(6,6,18,.95);backdrop-filter:blur(20px);border-bottom:1px solid var(--line)}
.vnav-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:1.15rem;color:var(--snow);text-decoration:none;display:flex;align-items:center;gap:8px}
.vdot{width:8px;height:8px;background:var(--teal);border-radius:50%;animation:dp 2s ease-in-out infinite}
@keyframes dp{0%,100%{box-shadow:0 0 0 0 rgba(0,232,212,.5)}50%{box-shadow:0 0 0 7px rgba(0,232,212,0)}}
.vnav-links{display:flex;align-items:center;gap:1.2rem}
.vnav-link{font-size:.8rem;color:var(--fog);text-decoration:none;transition:color .2s}
.vnav-link:hover{color:var(--snow)}

/* HERO */
.vhero{padding:64px 5vw 48px;text-align:center;position:relative;z-index:1}
.vhero::before{content:'';position:absolute;top:-60px;left:50%;transform:translateX(-50%);width:800px;height:360px;pointer-events:none;background:radial-gradient(ellipse,rgba(0,232,212,0.06) 0%,rgba(125,255,107,0.03) 40%,transparent 70%)}
.vtag{display:inline-flex;align-items:center;gap:7px;background:rgba(0,232,212,.07);border:1px solid rgba(0,232,212,.2);border-radius:100px;padding:5px 15px;margin-bottom:1.5rem;font-family:'JetBrains Mono',monospace;font-size:.65rem;color:var(--teal);letter-spacing:.1em}
.vtdot{width:5px;height:5px;background:var(--teal);border-radius:50%;animation:dp 1.5s ease-in-out infinite}
.vhero h1{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(2rem,5vw,3.4rem);letter-spacing:-.035em;line-height:1.06;margin-bottom:.9rem}
.vhero h1 em{font-style:normal;color:var(--teal)}
.vhero p{color:var(--fog);font-size:.95rem;font-weight:300;max-width:460px;margin:0 auto;line-height:1.8}

/* TABS */
.mtabs{display:flex;justify-content:center;gap:.5rem;padding:2rem 5vw 0;position:relative;z-index:1;flex-wrap:wrap}
.mtab{display:flex;align-items:center;gap:8px;padding:11px 26px;border-radius:10px;border:1px solid var(--line2);background:var(--panel);color:var(--fog);font-size:.87rem;font-weight:500;cursor:pointer;transition:all .25s;font-family:'DM Sans',sans-serif}
.mtab.active{background:rgba(0,232,212,.08);border-color:var(--teal);color:var(--teal)}
.mtab:hover:not(.active){color:var(--mist)}

/* CONTENT */
.vcontent{padding:2.5rem 5vw 80px;position:relative;z-index:1;max-width:860px;margin:0 auto;width:100%}

/* ─── VERIFY PANEL ─── */
.vcard{background:var(--card);border:1px solid var(--line2);border-radius:20px;padding:32px}
.vcard-eye{font-family:'JetBrains Mono',monospace;font-size:.63rem;color:var(--teal);letter-spacing:.12em;text-transform:uppercase;margin-bottom:.5rem}
.vcard-title{font-family:'Syne',sans-serif;font-weight:800;font-size:1.35rem;letter-spacing:-.025em;margin-bottom:.35rem}
.vcard-sub{font-size:.84rem;color:var(--fog);margin-bottom:1.7rem;line-height:1.65}

.srow{display:flex;gap:.7rem;flex-wrap:wrap}
.cert-inp{flex:1;min-width:200px;background:var(--card2);border:1px solid var(--line2);border-radius:10px;color:var(--snow);font-family:'JetBrains Mono',monospace;font-size:1rem;padding:13px 17px;outline:none;letter-spacing:.14em;text-transform:uppercase;transition:border-color .2s}
.cert-inp::placeholder{text-transform:none;letter-spacing:0;font-family:'DM Sans',sans-serif;font-size:.87rem;opacity:.5}
.cert-inp:focus{border-color:var(--teal);box-shadow:0 0 0 3px rgba(0,232,212,.07)}
.btn-v{background:var(--teal);color:var(--bg);font-weight:700;font-size:.9rem;padding:13px 26px;border-radius:10px;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .22s;white-space:nowrap;display:flex;align-items:center;gap:7px}
.btn-v:hover{box-shadow:0 4px 18px var(--teal-g);transform:translateY(-1px)}
.btn-v:disabled{opacity:.4;cursor:not-allowed;transform:none}

.demo-hint{margin-top:.9rem;padding:10px 14px;background:rgba(255,209,102,.05);border:1px solid rgba(255,209,102,.15);border-radius:8px;font-size:.76rem;color:var(--fog)}
.demo-id{background:none;border:none;color:var(--teal);cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:.72rem;letter-spacing:.07em;padding:0 3px;transition:opacity .15s}
.demo-id:hover{opacity:.7}

.verr{background:rgba(255,92,135,.06);border:1px solid rgba(255,92,135,.22);border-radius:12px;padding:14px 18px;display:flex;align-items:center;gap:10px;font-size:.84rem;color:#FF8FAD;margin-top:1rem;animation:fadein .25s ease}

.vsuccess-badge{display:flex;align-items:center;gap:11px;background:rgba(125,255,107,.06);border:1px solid rgba(125,255,107,.2);border-radius:12px;padding:14px 18px;margin-bottom:1.2rem;animation:fadein .3s ease}
.vsb-icon{font-size:1.5rem}
.vsb-text strong{display:block;color:var(--lime);font-size:.9rem;margin-bottom:2px}
.vsb-text span{font-size:.79rem;color:var(--mist)}

/* ─── DIGITAL CERTIFICATE ─── */
.dcert{background:var(--card2);border:1px solid var(--line2);border-radius:20px;overflow:hidden;position:relative;animation:fadein .4s ease}
.dcert-topbar{height:5px;background:linear-gradient(90deg,var(--teal),var(--lime),var(--gold))}
.dcert-inner{padding:36px 38px}
@media(max-width:580px){.dcert-inner{padding:22px 18px}}

.dc-wm{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) rotate(-15deg);font-family:'Syne',sans-serif;font-weight:800;font-size:7rem;opacity:.018;color:var(--teal);letter-spacing:-.05em;pointer-events:none;white-space:nowrap}

.dc-hd{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:2rem;padding-bottom:1.5rem;border-bottom:1px solid var(--line);flex-wrap:wrap;gap:1rem;position:relative;z-index:1}
.dc-brand{display:flex;align-items:center;gap:9px}
.dc-brand-dot{width:9px;height:9px;background:var(--teal);border-radius:50%}
.dc-brand-name{font-family:'Syne',sans-serif;font-weight:800;font-size:.97rem}
.dc-brand-tag{font-family:'JetBrains Mono',monospace;font-size:.56rem;color:var(--fog);letter-spacing:.07em;margin-top:1px}
.dc-id-chip{font-family:'JetBrains Mono',monospace;font-size:.68rem;color:var(--teal);background:rgba(0,232,212,.08);border:1px solid rgba(0,232,212,.2);padding:5px 13px;border-radius:6px;letter-spacing:.1em}

.dc-center{text-align:center;margin-bottom:1.8rem;position:relative;z-index:1}
.dc-certifies{font-family:'Playfair Display',serif;font-style:italic;font-size:1.05rem;color:var(--mist);margin-bottom:.4rem}
.dc-name{font-family:'Playfair Display',serif;font-weight:900;font-size:clamp(1.9rem,5vw,3rem);letter-spacing:-.02em;color:var(--snow);line-height:1.1;margin-bottom:.6rem}
.dc-completed{font-size:.88rem;color:var(--mist);font-style:italic}
.dc-completed strong{font-style:normal;color:var(--teal);font-weight:700}

.dc-prog{background:linear-gradient(135deg,rgba(0,232,212,.07),rgba(125,255,107,.05));border:1px solid rgba(0,232,212,.14);border-radius:13px;padding:17px 22px;margin-bottom:1.8rem;text-align:center;position:relative;z-index:1}
.dc-prog-lbl{font-family:'JetBrains Mono',monospace;font-size:.58rem;color:var(--fog);letter-spacing:.1em;text-transform:uppercase;margin-bottom:.35rem}
.dc-prog-name{font-family:'Syne',sans-serif;font-weight:800;font-size:1.1rem;letter-spacing:-.02em;color:var(--teal)}
.dc-prog-sub{font-size:.78rem;color:var(--mist);margin-top:.3rem}

.dc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(185px,1fr));gap:1px;background:var(--line);border:1px solid var(--line);border-radius:12px;overflow:hidden;margin-bottom:1.8rem;position:relative;z-index:1}
.dc-cell{background:var(--card);padding:13px 16px}
.dc-cell-k{font-family:'JetBrains Mono',monospace;font-size:.56rem;color:var(--fog);letter-spacing:.09em;text-transform:uppercase;margin-bottom:4px}
.dc-cell-v{font-size:.83rem;font-weight:600;color:var(--snow);line-height:1.35}

.dc-skills{margin-bottom:1.8rem;position:relative;z-index:1}
.dc-skills-lbl{font-family:'JetBrains Mono',monospace;font-size:.58rem;color:var(--fog);letter-spacing:.1em;text-transform:uppercase;margin-bottom:.7rem}
.dc-chips{display:flex;gap:.4rem;flex-wrap:wrap}
.dc-chip{font-size:.72rem;padding:4px 11px;border-radius:100px;background:rgba(255,255,255,.05);border:1px solid var(--line2);color:var(--mist)}
.dc-chip.hi{background:rgba(0,232,212,.08);border-color:rgba(0,232,212,.22);color:var(--teal)}

.dc-ft{display:flex;justify-content:space-between;align-items:flex-end;padding-top:1.5rem;border-top:1px solid var(--line);flex-wrap:wrap;gap:1rem;position:relative;z-index:1}
.dc-sig{text-align:center}
.dc-sig-line{width:110px;height:1px;background:var(--line2);margin:0 auto .35rem}
.dc-sig-name{font-family:'Syne',sans-serif;font-size:.76rem;font-weight:700}
.dc-sig-role{font-family:'JetBrains Mono',monospace;font-size:.55rem;color:var(--fog);letter-spacing:.06em}
.dc-seal{width:60px;height:60px;border-radius:50%;border:2px solid rgba(0,232,212,.25);display:flex;align-items:center;justify-content:center;font-size:1.6rem;background:rgba(0,232,212,.04)}

.cert-acts{display:flex;gap:.6rem;flex-wrap:wrap;margin-top:1rem}
.btn-act{display:flex;align-items:center;gap:6px;padding:10px 20px;border-radius:8px;font-size:.82rem;font-weight:600;cursor:pointer;transition:all .2s;font-family:'DM Sans',sans-serif;text-decoration:none}
.btn-act.primary{background:var(--teal);color:var(--bg);border:none}
.btn-act.primary:hover{box-shadow:0 4px 16px var(--teal-g);transform:translateY(-1px)}
.btn-act.ghost{background:transparent;color:var(--mist);border:1px solid var(--line2)}
.btn-act.ghost:hover{color:var(--snow);border-color:var(--line3)}

/* ─── REGISTER PANEL ─── */
.rcard{background:var(--card);border:1px solid var(--line2);border-radius:20px;overflow:hidden}
.rcard-hd{padding:26px 30px 20px;border-bottom:1px solid var(--line);background:linear-gradient(135deg,rgba(0,232,212,.04),rgba(125,255,107,.02))}
.rcard-top{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.8rem;margin-bottom:.3rem}
.rcard-title{font-family:'Syne',sans-serif;font-weight:800;font-size:1.25rem;letter-spacing:-.025em}
.live-pill{display:flex;align-items:center;gap:6px;background:rgba(125,255,107,.08);border:1px solid rgba(125,255,107,.2);border-radius:6px;padding:4px 11px;font-family:'JetBrains Mono',monospace;font-size:.6rem;color:var(--lime);letter-spacing:.07em}
.live-dot{width:5px;height:5px;background:var(--lime);border-radius:50%;animation:dp 1.5s ease-in-out infinite}
.rcard-sub{font-size:.82rem;color:var(--fog)}
.rcard-body{padding:26px 30px 30px}
@media(max-width:580px){.rcard-hd,.rcard-body{padding-left:18px;padding-right:18px}}

/* Progress steps */
.pbar{display:flex;align-items:center;gap:0;margin-bottom:2rem}
.pbar-seg{height:3px;flex:1;background:var(--line2);transition:background .35s;border-radius:2px}
.pbar-seg.done{background:var(--lime)}
.pbar-seg.active{background:var(--teal);animation:glow .9s ease-in-out infinite alternate}
@keyframes glow{from{box-shadow:none}to{box-shadow:0 0 8px var(--teal)}}
.pbar-dot{width:28px;height:28px;border-radius:50%;border:2px solid var(--line2);display:flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:700;font-family:'JetBrains Mono',monospace;color:var(--fog);transition:all .3s;flex-shrink:0;background:var(--card)}
.pbar-dot.done{border-color:var(--lime);color:var(--lime);background:rgba(125,255,107,.08)}
.pbar-dot.active{border-color:var(--teal);color:var(--teal);background:rgba(0,232,212,.08)}

.slbl{font-family:'JetBrains Mono',monospace;font-size:.61rem;color:var(--fog);letter-spacing:.08em;text-transform:uppercase;margin-bottom:1.4rem}
.slbl strong{color:var(--teal)}

/* Form fields */
.fg{display:grid;grid-template-columns:1fr 1fr;gap:.85rem;margin-bottom:.85rem}
@media(max-width:540px){.fg{grid-template-columns:1fr}}
.fr{margin-bottom:.85rem}
.fl{display:flex;gap:.5rem;align-items:center;font-size:.73rem;font-weight:600;color:var(--mist);margin-bottom:5px;letter-spacing:.02em}
.fl-hint{font-family:'JetBrains Mono',monospace;font-size:.58rem;color:var(--fog);font-weight:400}
.fi,.fs,.fta{width:100%;background:var(--card2);border:1px solid var(--line2);border-radius:9px;color:var(--snow);font-family:'DM Sans',sans-serif;font-size:.87rem;padding:11px 13px;outline:none;transition:all .2s;-webkit-appearance:none}
.fi:focus,.fs:focus,.fta:focus{border-color:var(--teal);box-shadow:0 0 0 3px rgba(0,232,212,.07)}
.fi.loading{border-color:var(--gold);animation:loadp 1s ease-in-out infinite}
@keyframes loadp{0%,100%{border-color:rgba(255,209,102,.35)}50%{border-color:var(--gold)}}
.fi.ok{border-color:var(--lime)}
.fi.err{border-color:var(--rose)}
.fs option{background:var(--card2)}
.fta{resize:vertical;min-height:68px}
.fhint{font-size:.69rem;color:var(--fog);margin-top:4px}
.fhint.ok{color:var(--lime)}
.fhint.err{color:var(--rose)}

/* Pincode */
.pin-wrap{position:relative}
.pin-spin{position:absolute;right:12px;top:50%;transform:translateY(-50%);width:15px;height:15px;border:2px solid var(--line2);border-top-color:var(--gold);border-radius:50%;animation:spin .6s linear infinite}
@keyframes spin{to{transform:translateY(-50%) rotate(360deg)}}
.pin-ok{position:absolute;right:12px;top:50%;transform:translateY(-50%);color:var(--lime);font-size:.9rem;font-weight:700}

/* Tech selector */
.tech-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(148px,1fr));gap:.55rem;margin-bottom:.85rem}
.tech-opt{padding:9px 11px;border-radius:9px;border:1px solid var(--line2);background:var(--card2);cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:7px;font-size:.79rem;font-weight:500;color:var(--fog)}
.tech-opt:hover{border-color:var(--line3);color:var(--mist)}
.tech-opt.sel{border-color:var(--teal);background:rgba(0,232,212,.08);color:var(--teal)}
.tech-opt-icon{font-size:.95rem;flex-shrink:0}

/* Duration pills */
.dpills{display:flex;gap:.45rem;flex-wrap:wrap}
.dpill{padding:8px 16px;border-radius:7px;border:1px solid var(--line2);background:var(--card2);cursor:pointer;transition:all .2s;font-size:.81rem;font-weight:500;color:var(--fog);font-family:'DM Sans',sans-serif}
.dpill:hover{color:var(--mist);border-color:var(--line3)}
.dpill.sel{border-color:var(--teal);background:rgba(0,232,212,.08);color:var(--teal)}

/* Performance */
.pfbtns{display:flex;gap:.45rem;flex-wrap:wrap}
.pfbtn{padding:8px 16px;border-radius:7px;border:1px solid var(--line2);background:var(--card2);cursor:pointer;font-size:.8rem;font-weight:500;color:var(--fog);transition:all .2s;font-family:'DM Sans',sans-serif}
.pfbtn.s-excellent{border-color:var(--lime);background:rgba(125,255,107,.08);color:var(--lime)}
.pfbtn.s-good{border-color:var(--teal);background:rgba(0,232,212,.08);color:var(--teal)}
.pfbtn.s-satisfactory{border-color:var(--gold);background:rgba(255,209,102,.08);color:var(--gold)}
.pfbtn.s-basic{border-color:var(--amber);background:rgba(255,168,67,.08);color:var(--amber)}

/* Inst type */
.itypebtn{padding:8px 15px;border-radius:7px;border:1px solid var(--line2);background:var(--card2);cursor:pointer;transition:all .2s;font-size:.8rem;font-weight:500;color:var(--fog);font-family:'DM Sans',sans-serif}
.itypebtn.sel{border-color:var(--violet);background:rgba(168,85,247,.08);color:var(--violet)}

/* Nav */
.rnav{display:flex;justify-content:space-between;align-items:center;margin-top:1.8rem;flex-wrap:wrap;gap:.8rem}
.btn-next{background:var(--teal);color:var(--bg);font-weight:700;font-size:.9rem;padding:12px 24px;border-radius:9px;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .22s;display:flex;align-items:center;gap:7px}
.btn-next:hover{box-shadow:0 4px 18px var(--teal-g);transform:translateY(-1px)}
.btn-next:disabled{opacity:.35;cursor:not-allowed;transform:none}
.btn-bk{background:transparent;color:var(--fog);font-size:.87rem;padding:12px 18px;border-radius:9px;border:1px solid var(--line2);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s}
.btn-bk:hover{color:var(--snow);border-color:var(--line3)}

/* Preview box */
.preview-box{background:rgba(0,232,212,.04);border:1px solid rgba(0,232,212,.14);border-radius:12px;padding:15px 17px;margin-top:.5rem;margin-bottom:.5rem}
.pb-lbl{font-family:'JetBrains Mono',monospace;font-size:.58rem;color:var(--teal);letter-spacing:.1em;text-transform:uppercase;margin-bottom:.7rem}
.pb-row{display:flex;justify-content:space-between;font-size:.78rem;padding:5px 0;border-bottom:1px solid var(--line)}
.pb-row:last-child{border-bottom:none}
.pb-k{color:var(--fog)}
.pb-v{color:var(--snow);font-weight:500}

/* ─── SUCCESS ─── */
.succ-wrap{text-align:center;padding:16px 0;animation:fadein .45s ease}
.succ-icon{font-size:3.2rem;display:block;margin-bottom:1rem}
.succ-title{font-family:'Syne',sans-serif;font-weight:800;font-size:1.45rem;letter-spacing:-.025em;color:var(--lime);margin-bottom:.45rem}
.succ-sub{font-size:.86rem;color:var(--fog);margin-bottom:1.8rem;line-height:1.7;max-width:420px;margin-left:auto;margin-right:auto}

.cid-box{background:linear-gradient(135deg,rgba(0,232,212,.08),rgba(125,255,107,.06));border:1px solid rgba(0,232,212,.24);border-radius:16px;padding:26px;max-width:380px;margin:0 auto 1.4rem}
.cid-lbl{font-family:'JetBrains Mono',monospace;font-size:.6rem;color:var(--fog);letter-spacing:.12em;text-transform:uppercase;margin-bottom:.55rem}
.cid-val{font-family:'JetBrains Mono',monospace;font-weight:700;font-size:2.1rem;letter-spacing:.18em;color:var(--teal);margin-bottom:.6rem}
.cid-copy{display:inline-flex;align-items:center;gap:6px;background:rgba(0,232,212,.1);color:var(--teal);font-size:.77rem;padding:5px 14px;border-radius:6px;cursor:pointer;border:none;font-family:'DM Sans',sans-serif;transition:all .2s}
.cid-copy:hover{background:rgba(0,232,212,.16)}
.cid-copy.cp{color:var(--lime)}

.mini-cert{background:var(--card2);border:1px solid var(--line2);border-radius:11px;padding:15px 18px;text-align:left;margin-bottom:1.2rem;max-width:440px;margin-left:auto;margin-right:auto}
.mc-row{display:flex;justify-content:space-between;font-size:.79rem;padding:5px 0;border-bottom:1px solid var(--line)}
.mc-row:last-child{border-bottom:none}
.mc-k{color:var(--fog)}
.mc-v{color:var(--snow);font-weight:500;text-align:right;max-width:60%}

.succ-acts{display:flex;gap:.65rem;justify-content:center;flex-wrap:wrap}

/* ─── RECENT LIST ─── */
.recent-sec{margin-top:1.8rem}
.recent-lbl{font-family:'JetBrains Mono',monospace;font-size:.61rem;color:var(--fog);letter-spacing:.1em;text-transform:uppercase;margin-bottom:.9rem;display:flex;align-items:center;gap:8px}
.recent-lbl::before{content:'—';opacity:.4}
.recent-list{display:flex;flex-direction:column;gap:.45rem}
.ri{background:var(--card);border:1px solid var(--line);border-radius:10px;padding:11px 15px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem;cursor:pointer;transition:all .2s}
.ri:hover{border-color:var(--line2);background:var(--card2)}
.ri-l{display:flex;align-items:center;gap:10px}
.ri-ico{font-size:1.1rem}
.ri-cid{font-family:'JetBrains Mono',monospace;font-size:.7rem;color:var(--teal);letter-spacing:.08em}
.ri-name{font-size:.82rem;font-weight:500;color:var(--snow)}
.ri-r{font-size:.73rem;color:var(--fog)}

/* UTILS */
@keyframes fadein{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
.toast{position:fixed;bottom:28px;left:50%;transform:translateX(-50%);background:var(--lime);color:var(--bg);font-weight:700;font-size:.82rem;padding:10px 22px;border-radius:8px;z-index:999;font-family:'DM Sans',sans-serif;animation:fadein .28s ease;white-space:nowrap}

/* FOOTER */
.vfoot{border-top:1px solid var(--line);padding:20px 5vw;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;font-size:.74rem;color:var(--fog);position:relative;z-index:1}
.wa-f{position:fixed;bottom:22px;right:22px;width:48px;height:48px;border-radius:50%;background:#25D366;display:flex;align-items:center;justify-content:center;font-size:1.3rem;cursor:pointer;z-index:99;text-decoration:none;box-shadow:0 4px 16px rgba(37,211,102,.33);animation:wab 3s ease-in-out infinite}
@keyframes wab{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
`;

